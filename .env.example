# ─── Supabase (server-side only — the browser never talks to Supabase) ──
# Project Settings → API.
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# In Supabase Dashboard → Auth → URL Configuration → Redirect URLs, add:
#   http://localhost:3000/api/auth/google/callback
#   https://<your-production-domain>/api/auth/google/callback

# ─── Gemini (server-side only, never exposed to the browser bundle) ─────
# https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key"

# ─── Unsplash (server-side only — used to fetch real photos for AI-generated
# destinations; without it, generated destinations fall back to a small
# generic scenic-India photo pool). Free "Demo" apps work fine (50 req/hour).
# https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY="your-unsplash-access-key"

# ─── Outbound booking (optional) ────────────────────────────────────────
# Travelpayouts affiliate marker for "Book this trip" deep links.
# When unset, the app sends travellers to a live Booking.com search instead.
TRAVELPAYOUTS_MARKER=""
# Client-side marker (safe to expose) used to attribute outbound clicks.
VITE_TRAVELPAYOUTS_MARKER=""

# ─── Frontend build (Netlify) ───────────────────────────────────────────
# Absolute URL of the Render backend, baked into the frontend bundle at
# build time. Leave unset for a combined deploy (frontend and backend on
# the same origin) — the app then falls back to relative "/api" requests.
VITE_API_URL=""

# ─── Server ─────────────────────────────────────────────────────────────
# The Vite dev proxy forwards /api to this port. On Render, PORT is injected.
PORT=3002
# This API's own public origin — used to build the OAuth callback URL
# (`<APP_ORIGIN>/api/auth/google/callback`). Requests to /api/* arrive
# through Vite's dev proxy, which rewrites the Host header to its own target
# (3002), so this can't be reliably inferred from the request in dev. Set to
# this Render service's own https://... URL in production.
APP_ORIGIN="http://localhost:3000"
# The frontend's own public origin (Netlify), only needed once frontend and
# backend are split across different domains. Used for two things: (1) the
# CORS allow-list, so the browser accepts the cross-origin session cookie;
# (2) rewriting post-login redirects (e.g. `/discover`) so they land back on
# the frontend instead of on this API. Leave unset for a combined deploy
# where one Render service serves both — redirects then stay relative.
FRONTEND_ORIGIN=""
