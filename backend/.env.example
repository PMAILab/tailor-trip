# ─── Supabase (server-side only — the browser never talks to Supabase) ──
# Project Settings → API.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# In Supabase Dashboard → Auth → URL Configuration → Redirect URLs, add:
#   http://localhost:3000/api/auth/google/callback
#   https://<your-netlify-domain>/api/auth/google/callback
# The second one is the Netlify domain, not Render's — Netlify proxies
# /api/* through to Render (see ../netlify.toml), so that's what the browser
# actually navigates to and what needs to be allow-listed.
# Data API Settings → "Exposed schemas" must also include "tailortrip"
# (public is exposed by default, custom schemas are not) — see
# supabase/schema.sql.

# ─── Gemini (server-side only, never exposed to the browser bundle) ─────
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# ─── Unsplash (server-side only — used to fetch real photos for AI-generated
# destinations; without it, generated destinations fall back to a small
# generic scenic-India photo pool). Free "Demo" apps work fine (50 req/hour).
# https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# ─── Outbound booking (optional) ────────────────────────────────────────
# Travelpayouts affiliate marker for "Book this trip" deep links.
# When unset, the app sends travellers to a live Booking.com search instead.
TRAVELPAYOUTS_MARKER=

# ─── Server ─────────────────────────────────────────────────────────────
# The Vite dev proxy forwards /api to this port. On Render, PORT is injected.
PORT=3002
# The origin the browser actually navigates to for the OAuth round trip —
# used to build the callback URL (`<APP_ORIGIN>/api/auth/google/callback`)
# that Google/Supabase redirects back to. Once Netlify is proxying /api/*,
# this must be the Netlify domain (not Render's own URL) — Google redirects
# the browser here directly, and only Netlify's origin also has the
# session cookie's first-party context for the frontend to read it back.
# In dev, requests to /api/* arrive through Vite's proxy, which rewrites the
# Host header to its own target (3002), so this can't be reliably inferred
# from the request there either.
APP_ORIGIN=http://localhost:3000
# The frontend's own public origin (same as APP_ORIGIN once Netlify is
# proxying /api/*) — used for the CORS allow-list, as defense-in-depth for
# anyone hitting this API directly instead of through the Netlify proxy.
# Leave unset for a combined deploy where one Render service serves both.
FRONTEND_ORIGIN=
