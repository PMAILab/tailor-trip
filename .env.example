# ─── Supabase (server-side) ─────────────────────────────────────────────
# Project Settings → API. Service role key must stay server-side only.
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Supabase (client-side, safe to expose — anon key only) ─────────────
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"

# ─── Gemini (server-side only, never exposed to the browser bundle) ─────
# https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key"

# ─── Outbound booking (optional) ────────────────────────────────────────
# Travelpayouts affiliate marker for "Book this trip" deep links.
# When unset, the app sends travellers to a live Booking.com search instead.
TRAVELPAYOUTS_MARKER=""
# Client-side marker (safe to expose) used to attribute outbound clicks.
VITE_TRAVELPAYOUTS_MARKER=""

# ─── Server ─────────────────────────────────────────────────────────────
# The Vite dev proxy forwards /api to this port. On Render, PORT is injected.
PORT=3002
